ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: restrict who can use the scorer.
# Set a secret code here; users must enter it in the UI before scoring.
# Leave unset (or empty) to allow open access.
SCORER_ACCESS_TOKEN=

# Set to "true" when SCORER_ACCESS_TOKEN is set — shows the access code input in the UI.
NEXT_PUBLIC_REQUIRE_ACCESS_TOKEN=false
